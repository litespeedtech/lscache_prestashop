<?xml version="1.0"?>
<ruleset name="LiteSpeedCache">
    <description>PHP CodeSniffer config for litespeedcache module</description>

    <file>.</file>
    <exclude-pattern>vendor/</exclude-pattern>
    <exclude-pattern>tests/</exclude-pattern>
    <exclude-pattern>node_modules/</exclude-pattern>

    <!-- Disable the PS version guard rule for namespaced files -->
    <!-- PHP 8+ does not allow code before namespace declarations -->
    <rule ref="PSR12"/>

    <rule ref="Generic.Files.LineLength">
        <properties>
            <property name="lineLimit" value="200"/>
            <property name="absoluteLineLimit" value="0"/>
        </properties>
    </rule>
</ruleset>
