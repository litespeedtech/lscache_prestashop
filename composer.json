{
    "name": "iitespeedtech/litespeedcache",
    "description": "PrestaShop Full Page Cache Module for LiteSpeed Web Server",
    "homepage": "https://github.com/ecomlabs-es/lscache_prestashop",
    "type": "prestashop-module",
    "config": {
        "preferred-install": "dist",
        "classmap-authoritative": false,
        "optimize-autoloader": true,
        "prepend-autoloader": false
    },
    "autoload": {
        "psr-4": {
            "LiteSpeed\\Cache\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "LiteSpeed\\Cache\\Tests\\": "tests/"
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "prestashop/php-dev-tools": "^5.0",
        "friendsofphp/php-cs-fixer": "^3.94"
    },
    "scripts": {
        "cs-fix": "php-cs-fixer fix",
        "cs-check": "php-cs-fixer fix --dry-run --diff"
    },
    "author": "LiteSpeedTech",
    "license": "GPL-3.0+"
}
