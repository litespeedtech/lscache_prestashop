{% extends '@PrestaShop/Admin/layout.html.twig' %}

{% block content %}
<div class="row justify-content-center">
  <div class="col-xl-12">

    {# ============ LAST CRAWL STATUS ============ #}
    {% if lastState.date is defined %}
    <div class="card mb-4">
      <div class="card-header d-flex align-items-center justify-content-between">
        <h3 class="card-header-title mb-0">Last Crawl</h3>
        <small class="text-muted">{{ lastState.date }}</small>
      </div>
      <div class="card-body">
        <div class="row text-center mb-3">
          <div class="col-md-3">
            <div class="p-3 rounded" style="background:#f8f9fa; border:1px solid #e9ecef;">
              <div style="font-size:22px; font-weight:700; color:#343a40;">{{ lastState.total|default(0) }}</div>
              <small class="text-muted">Total URLs</small>
            </div>
          </div>
          <div class="col-md-3">
            <div class="p-3 rounded" style="background:#f8f9fa; border:1px solid #e9ecef;">
              <div style="font-size:22px; font-weight:700; color:#70b580;">{{ lastState.success|default(0) }}</div>
              <small class="text-muted">Success</small>
            </div>
          </div>
          <div class="col-md-3">
            <div class="p-3 rounded" style="background:#f8f9fa; border:1px solid #e9ecef;">
              <div style="font-size:22px; font-weight:700; color:#e84e6a;">{{ lastState.fail|default(0) }}</div>
              <small class="text-muted">Failed</small>
            </div>
          </div>
          <div class="col-md-3">
            <div class="p-3 rounded" style="background:#f8f9fa; border:1px solid #e9ecef;">
              <div style="font-size:22px; font-weight:700; color:#343a40;">{{ lastState.duration|default(0) }}s</div>
              <small class="text-muted">Duration</small>
            </div>
          </div>
        </div>

        {% if lastState.urls is defined and lastState.urls|length > 0 %}
        <div class="table-responsive" style="max-height:300px; overflow-y:auto;">
          <table class="table table-hover mb-0" style="font-size:13px;">
            <thead><tr>
              <th>#</th>
              <th>URL</th>
              <th style="width:120px;">Status</th>
              <th style="width:80px;">Action</th>
            </tr></thead>
            <tbody>
              {% for item in lastState.urls %}
              <tr>
                <td>{{ loop.index }}</td>
                <td><small><a href="{{ item.url }}" target="_blank" rel="noopener">{{ item.url|length > 80 ? item.url|slice(0, 80) ~ '...' : item.url }}</a></small></td>
                <td>
                  {% if item.blacklisted is defined and item.blacklisted %}
                    <span class="badge badge-danger">Blacklisted</span>
                  {% elseif item.cached is defined and item.cached %}
                    <span class="badge badge-success">Cached</span>
                  {% elseif item.success is defined and item.success %}
                    <span class="badge badge-info">Crawled</span>
                  {% elseif item.httpCode is defined and item.httpCode > 0 %}
                    <span class="badge badge-warning">Failed {{ item.httpCode }}</span>
                  {% else %}
                    <span class="badge badge-secondary">Pending</span>
                  {% endif %}
                </td>
                <td>
                  {% if not (item.blacklisted is defined and item.blacklisted) %}
                  <form method="post" class="d-inline">
                    <input type="hidden" name="blacklist_add" value="1">
                    <input type="hidden" name="blacklist_url" value="{{ item.url }}">
                    <button type="submit" class="btn btn-sm btn-outline-danger" title="Add to blacklist" style="padding:2px 6px;">
                      <i class="material-icons" style="font-size:14px;">block</i>
                    </button>
                  </form>
                  {% endif %}
                </td>
              </tr>
              {% endfor %}
            </tbody>
          </table>
        </div>
        {% endif %}

        <div class="mt-3 d-flex justify-content-between align-items-center">
          <div>
            <span class="badge badge-secondary mr-1">Pending</span>
            <span class="badge badge-success mr-1">Cached</span>
            <span class="badge badge-info mr-1">Crawled</span>
            <span class="badge badge-danger mr-1">Blacklisted</span>
            <span class="badge badge-warning">Failed</span>
          </div>
          <form method="post" class="d-inline">
            <input type="hidden" name="reset_state" value="1">
            <button type="submit" class="btn btn-sm btn-outline-secondary">Reset Position</button>
          </form>
        </div>
      </div>
    </div>
    {% endif %}

    {# ============ CRAWLER SETTINGS ============ #}
    <div class="card mb-4">
      <div class="card-header">
        <h3 class="card-header-title">Crawler Settings</h3>
      </div>
      <div class="card-body">
        <form method="post">

          <div class="form-group row">
            <label class="form-control-label col-sm-3" for="sitemap_url">
              Sitemap XML URL <span class="text-danger">*</span>
            </label>
            <div class="col-sm-9">
              <input type="url" class="form-control" id="sitemap_url" name="sitemap_url"
                value="{{ sitemapUrl }}"
                placeholder="https://example.com/sitemap.xml" required>
            </div>
          </div>

          <div class="form-group row">
            <label class="form-control-label col-sm-3" for="shop_url">
              Shop URL <span class="text-muted">(optional)</span>
            </label>
            <div class="col-sm-9">
              <input type="url" class="form-control" id="shop_url" name="shop_url"
                value="{{ shopUrl }}"
                placeholder="https://example.com">
              <small class="form-text text-muted">Auto-detected if empty.</small>
            </div>
          </div>

          <div class="form-group row">
            <label class="form-control-label col-sm-3" for="useragent">
              Extra User Agent <span class="text-muted">(optional)</span>
            </label>
            <div class="col-sm-9">
              <input type="text" class="form-control" id="useragent" name="useragent"
                value="{{ userAgent }}"
                placeholder="e.g. mobile">
            </div>
          </div>

          <hr>
          <h4 class="mb-3" style="font-size:15px; font-weight:600;">Performance</h4>

          <div class="form-group row">
            <label class="form-control-label col-sm-3">Performance Profile</label>
            <div class="col-sm-9">
              <div class="d-flex flex-wrap" style="gap:8px;" id="profile-selector">
                {% set currentProfile = warmupSettings.profile|default('medium') %}
                {% set profileLabels = {
                  'low': {'name': 'Low', 'desc': '1 request · 500ms delay'},
                  'medium': {'name': 'Medium', 'desc': '3 requests · 100ms delay'},
                  'high': {'name': 'High', 'desc': '8 requests · no delay'}
                } %}
                {% for key, label in profileLabels %}
                <label class="btn {{ currentProfile == key ? 'btn-primary' : 'btn-outline-secondary' }}" style="min-width:120px; cursor:pointer;">
                  <input type="radio" name="profile" value="{{ key }}" {{ currentProfile == key ? 'checked' : '' }} style="display:none;">
                  <div style="font-weight:600;">{{ label.name }}</div>
                  <small style="font-size:11px; opacity:0.8;">{{ label.desc }}</small>
                </label>
                {% endfor %}
                <label class="btn {{ currentProfile == 'custom' ? 'btn-primary' : 'btn-outline-secondary' }}" style="min-width:100px; cursor:pointer;">
                  <input type="radio" name="profile" value="custom" {{ currentProfile == 'custom' ? 'checked' : '' }} style="display:none;">
                  <div style="font-weight:600;">Custom</div>
                  <small style="font-size:11px; opacity:0.8;">Manual config</small>
                </label>
              </div>
              <small class="form-text text-muted mt-2">
                <strong>Low:</strong> 1 request at a time, 500ms pause between requests, stops at load 0.5 — ideal for shared hosting.<br>
                <strong>Medium:</strong> 3 concurrent requests, 100ms pause, stops at load 2 — good for VPS/dedicated.<br>
                <strong>High:</strong> 8 concurrent requests, no pause, no load limit — for powerful servers only.
              </small>
            </div>
          </div>

          <div id="custom-fields" style="{{ currentProfile == 'custom' ? '' : 'display:none;' }}">
            <div class="form-group row">
              <label class="form-control-label col-sm-3" for="concurrent">Concurrent Requests</label>
              <div class="col-sm-9">
                <input type="number" class="form-control" id="concurrent" name="concurrent"
                  value="{{ warmupSettings.concurrent }}" min="1" max="10" style="max-width:120px;">
                <small class="form-text text-muted">Number of URLs to crawl in parallel (1-10). Higher = faster but more server load.</small>
              </div>
            </div>

            <div class="form-group row">
              <label class="form-control-label col-sm-3" for="crawl_delay">Crawl Delay (ms)</label>
              <div class="col-sm-9">
                <input type="number" class="form-control" id="crawl_delay" name="crawl_delay"
                  value="{{ warmupSettings.crawl_delay }}" min="0" max="10000" step="50" style="max-width:160px;">
                <small class="form-text text-muted">Pause between each batch of requests in milliseconds. 500 = half second. 0 = no delay.</small>
              </div>
            </div>

            <div class="form-group row">
              <label class="form-control-label col-sm-3" for="crawl_timeout">Timeout per URL (seconds)</label>
              <div class="col-sm-9">
                <input type="number" class="form-control" id="crawl_timeout" name="crawl_timeout"
                  value="{{ warmupSettings.crawl_timeout }}" min="5" max="120" style="max-width:120px;">
                <small class="form-text text-muted">Maximum wait time per URL before skipping (5-120).</small>
              </div>
            </div>

            <div class="form-group row">
              <label class="form-control-label col-sm-3" for="load_limit">Server Load Limit</label>
              <div class="col-sm-9">
                <input type="number" class="form-control" id="load_limit" name="load_limit"
                  value="{{ warmupSettings.load_limit }}" min="0" max="100" step="0.5" style="max-width:120px;">
                <small class="form-text text-muted">Stop crawling when server 1-min load average exceeds this value. Recommended: 0.5 per CPU core. 0 = no limit.</small>
              </div>
            </div>
          </div>

          <hr>
          <h4 class="mb-3" style="font-size:15px; font-weight:600;">Mobile Cache</h4>

          <div class="form-group row">
            <label class="form-control-label col-sm-3">Crawl with Mobile User-Agent</label>
            <div class="col-sm-9">
              <div class="custom-control custom-switch">
                <input type="checkbox" class="custom-control-input" id="mobile_crawl" name="mobile_crawl" value="1"
                  {{ warmupSettings.mobile_crawl ? 'checked' : '' }}>
                <label class="custom-control-label" for="mobile_crawl">Enable mobile crawling</label>
              </div>
              <small class="form-text text-muted">
                After the desktop crawl, re-crawl all URLs with a mobile user-agent to warm the mobile cache.
                {% if not diffMobile %}
                  <span class="text-warning">Warning: "Separate mobile cache" is not enabled in Cache Settings. Mobile crawling will have no effect.</span>
                {% endif %}
              </small>
            </div>
          </div>

          <div class="form-group row" id="mobile-ua-row" style="{{ warmupSettings.mobile_crawl ? '' : 'display:none;' }}">
            <label class="form-control-label col-sm-3" for="mobile_useragent">Mobile User-Agent</label>
            <div class="col-sm-9">
              <input type="text" class="form-control" id="mobile_useragent" name="mobile_useragent"
                value="{{ warmupSettings.mobile_useragent }}" style="max-width:500px;">
              <small class="form-text text-muted">Must contain a mobile token (iPhone, Android, Mobile) for LiteSpeed to serve the mobile cache variant.</small>
            </div>
          </div>

          <div class="form-group row mb-0">
            <div class="col-sm-9 offset-sm-3">
              <button type="submit" name="save_settings" value="1" class="btn btn-primary">Save Settings</button>
            </div>
          </div>
        </form>
      </div>
    </div>

    {# ============ RUN CRAWLER ============ #}
    <div class="card mb-4">
      <div class="card-header">
        <h3 class="card-header-title">Run Crawler</h3>
      </div>
      <div class="card-body">
        <div class="d-flex align-items-center justify-content-end">
          <div id="progress-wrapper" class="flex-grow-1 mr-3" style="display:none;">
            <div class="d-flex justify-content-between mb-1">
              <small id="warmup-status" class="text-muted">Initializing...</small>
              <small id="warmup-count" class="text-muted">0 / 0</small>
            </div>
            <div class="progress">
              <div id="warmup-bar" class="progress-bar progress-bar-striped progress-bar-animated bg-success"
                   role="progressbar" style="width: 0%">0%</div>
            </div>
          </div>
          <div class="d-flex align-items-center" style="white-space:nowrap;">
            <button type="button" id="btn-stop" class="btn btn-danger mr-2" style="display:none;">Stop</button>
            <button type="button" id="btn-warmup" class="btn btn-primary">Run Crawler</button>
          </div>
        </div>

        <pre id="warmup-log" class="bg-dark text-light p-3 rounded mt-3"
             style="display:none; max-height:400px; overflow-y:auto; font-size:12px;"></pre>
      </div>
    </div>

    {# ============ BLACKLIST ============ #}
    <div class="card mb-4">
      <div class="card-header d-flex align-items-center justify-content-between">
        <h3 class="card-header-title mb-0">Blacklist <span class="badge badge-secondary ml-2">{{ blacklist|length }}</span></h3>
        {% if blacklist|length > 0 %}
        <form method="post" class="d-inline">
          <input type="hidden" name="blacklist_clear" value="1">
          <button type="submit" class="btn btn-sm btn-outline-danger">Clear All</button>
        </form>
        {% endif %}
      </div>
      <div class="card-body">
        <form method="post" class="mb-3">
          <div class="input-group" style="max-width:600px;">
            <input type="url" class="form-control" name="blacklist_url" placeholder="https://example.com/page-to-skip">
            <div class="input-group-append">
              <button type="submit" name="blacklist_add" value="1" class="btn btn-outline-secondary">Add URL</button>
            </div>
          </div>
          <small class="form-text text-muted">URLs in the blacklist will be skipped during crawling.</small>
        </form>

        {% if blacklist|length > 0 %}
        <div class="table-responsive" style="max-height:200px; overflow-y:auto;">
          <table class="table table-hover mb-0" style="font-size:13px;">
            <tbody>
              {% for url in blacklist %}
              <tr>
                <td><small>{{ url }}</small></td>
                <td style="width:80px;" class="text-right">
                  <form method="post" class="d-inline">
                    <button type="submit" name="blacklist_remove" value="{{ url }}" class="btn btn-sm btn-outline-secondary" style="padding:2px 6px;">
                      <i class="material-icons" style="font-size:14px;">close</i>
                    </button>
                  </form>
                </td>
              </tr>
              {% endfor %}
            </tbody>
          </table>
        </div>
        {% else %}
          <p class="text-muted mb-0">No URLs blacklisted.</p>
        {% endif %}
      </div>
    </div>

    {# ============ CLI / CRON ============ #}
    <div class="card mb-4">
      <div class="card-header">
        <h3 class="card-header-title">Cron / CLI</h3>
      </div>
      <div class="card-body">
        <p class="text-muted mb-2">Schedule automatic cache warmup using a cron job:</p>
        <div class="input-group mb-3" style="max-width:700px;">
          <input type="text" class="form-control bg-dark text-light" style="font-family:monospace; font-size:13px;"
            value="{{ cliCommand }} {{ sitemapUrl ? sitemapUrl : 'https://yoursite.com/sitemap.xml' }}" readonly id="cron-command">
          <div class="input-group-append">
            <button type="button" class="btn btn-outline-secondary js-copy-text" data-text="{{ cliCommand }} {{ sitemapUrl ? sitemapUrl : 'https://yoursite.com/sitemap.xml' }}">Copy</button>
          </div>
        </div>
        <small class="form-text text-muted">
          Add this command to your server's crontab. Example: <code>0 3 * * * {{ cliCommand }} https://yoursite.com/sitemap.xml</code> (runs daily at 3 AM).
        </small>
      </div>
    </div>

  </div>
</div>
{% include "@Modules/litespeedcache/views/templates/admin/_tools_dropdown.html.twig" %}
{% endblock %}

{% block javascripts %}
  {{ parent() }}
  <script>
  (function() {
    var urlsEndpoint     = '{{ urlsAction }}';
    var crawlEndpoint    = '{{ crawlAction }}';
    var saveEndpoint     = '{{ saveStateAction }}';
    var loadCheckUrl     = '{{ loadCheckAction }}';
    var cdnEnabled       = {{ cdnEnabled ? 'true' : 'false' }};
    var blacklist        = {{ blacklist|json_encode|raw }};
    var warmupSettings   = {{ warmupSettings|json_encode|raw }};
    var abortCtrl        = null;
    var crawledUrls      = [];
    var startTime        = 0;

    var els = {
      bar:     document.getElementById('warmup-bar'),
      status:  document.getElementById('warmup-status'),
      count:   document.getElementById('warmup-count'),
      log:     document.getElementById('warmup-log'),
      wrapper: document.getElementById('progress-wrapper'),
      btn:     document.getElementById('btn-warmup'),
      stop:    document.getElementById('btn-stop')
    };

    var profilePresets = {{ profiles|json_encode|raw }};

    // Toggle profile selector
    var profileRadios = document.querySelectorAll('#profile-selector input[name="profile"]');
    var customFields = document.getElementById('custom-fields');
    profileRadios.forEach(function(radio) {
      radio.addEventListener('change', function() {
        // Update button styles
        document.querySelectorAll('#profile-selector label').forEach(function(l) {
          l.classList.remove('btn-primary');
          l.classList.add('btn-outline-secondary');
        });
        this.parentElement.classList.remove('btn-outline-secondary');
        this.parentElement.classList.add('btn-primary');

        // Show/hide custom fields
        customFields.style.display = this.value === 'custom' ? '' : 'none';

        // Apply preset values to warmupSettings for the crawler
        if (this.value !== 'custom' && profilePresets[this.value]) {
          var p = profilePresets[this.value];
          warmupSettings.concurrent = p.concurrent;
          warmupSettings.crawl_delay = p.crawl_delay;
          warmupSettings.crawl_timeout = p.crawl_timeout;
          warmupSettings.load_limit = p.load_limit;
        }
      });
    });

    // Toggle mobile UA field
    var mobileCheck = document.getElementById('mobile_crawl');
    var mobileRow = document.getElementById('mobile-ua-row');
    if (mobileCheck) {
      mobileCheck.addEventListener('change', function() {
        mobileRow.style.display = this.checked ? '' : 'none';
      });
    }

    function sleep(ms) { return new Promise(function(r) { setTimeout(r, ms); }); }

    function logLine(text) {
      els.log.textContent += text + '\n';
      els.log.scrollTop = els.log.scrollHeight;
    }

    function logHeader(title) {
      var sep = '='.repeat(60);
      els.log.textContent += '\n' + sep + '\n  ' + title + '\n' + sep + '\n\n';
      els.log.scrollTop = els.log.scrollHeight;
    }

    var globalCompleted = 0;
    var globalTotal = 0;

    function updateBar(current, total) {
      var pct = total > 0 ? Math.round((current / total) * 100) : 0;
      els.bar.style.width = pct + '%';
      els.bar.textContent = pct + '%';
      els.count.textContent = current + ' / ' + total;
    }

    function resetBar() {
      els.bar.style.width = '0%';
      els.bar.textContent = '0%';
      els.bar.className = 'progress-bar progress-bar-striped progress-bar-animated bg-success';
      els.count.textContent = '0 / 0';
    }

    function setRunning(running) {
      els.btn.disabled = running;
      els.stop.style.display = running ? '' : 'none';
      els.wrapper.style.display = running ? '' : 'none';
      els.log.style.display = 'block';
      if (!running) abortCtrl = null;
    }

    function isBlacklisted(url) { return blacklist.indexOf(url) !== -1; }

    function formatCacheInfo(data) {
      var parts = [];
      if (data.lscache) parts.push('LiteSpeed: ' + data.lscache);
      if (data.cfCache) parts.push('CDN: ' + data.cfCache);
      return parts.length ? ' [' + parts.join(' | ') + ']' : '';
    }

    async function checkServerLoad() {
      if (warmupSettings.load_limit <= 0) return true;
      try {
        var resp = await fetch(loadCheckUrl, { method: 'POST' });
        var data = await resp.json();
        return data.ok;
      } catch (e) {
        return true;
      }
    }

    async function crawlPhase(label, urls, cookie, userAgent) {
      var filtered = [];
      for (var j = 0; j < urls.length; j++) {
        if (isBlacklisted(urls[j])) {
          crawledUrls.push({ url: urls[j], httpCode: 0, lscache: '', cfCache: '', success: false, blacklisted: true });
        } else {
          filtered.push(urls[j]);
        }
      }
      var skipped = urls.length - filtered.length;
      var total = filtered.length;

      if (skipped > 0) logLine('  Skipped ' + skipped + ' blacklisted URLs.');
      if (total === 0) {
        logLine('  No URLs to process.');
        return { stopped: false, success: 0, fail: 0 };
      }

      els.status.textContent = label + '...';

      var concurrency = warmupSettings.concurrent || 3;
      var delayMs = Math.max(0, warmupSettings.crawl_delay || 0);
      var signal = abortCtrl ? abortCtrl.signal : null;
      var successCount = 0, failCount = 0;
      var queue = filtered.slice();
      var stopped = false;

      async function worker() {
        while (queue.length > 0 && !stopped) {
          if (signal && signal.aborted) { stopped = true; return; }

          // Server load check
          var loadOk = await checkServerLoad();
          while (!loadOk && !stopped) {
            logLine('  Server load too high, pausing 10s...');
            els.status.textContent = label + ' (paused: server load)';
            await sleep(10000);
            if (signal && signal.aborted) { stopped = true; return; }
            loadOk = await checkServerLoad();
          }

          var url = queue.shift();
          if (!url) return;

          try {
            var body = new FormData();
            body.append('url', url);
            body.append('useragent', userAgent);
            body.append('cookie', cookie || '');

            var resp = await fetch(crawlEndpoint, { method: 'POST', body: body, signal: signal });
            var data = await resp.json();

            if (data.success) { successCount++; } else { failCount++; }

            crawledUrls.push({
              url: url,
              httpCode: data.httpCode || 0,
              lscache: data.lscache || '',
              cfCache: data.cfCache || '',
              success: data.success,
              cached: data.cached || false
            });

            globalCompleted++;
            var statusLabel = data.cached ? 'CACHED' : (data.success ? 'CRAWLED' : 'FAIL');
            logLine('  ' + globalCompleted + '/' + globalTotal + '  ' + statusLabel + ' ' + data.httpCode + '  ' + url + formatCacheInfo(data));
            updateBar(globalCompleted, globalTotal);
          } catch (e) {
            if (e.name === 'AbortError') { stopped = true; return; }
            failCount++;
            globalCompleted++;
            logLine('  ' + globalCompleted + '/' + globalTotal + '  ERROR  ' + url);
            updateBar(globalCompleted, globalTotal);
          }

          if (delayMs > 0) await sleep(delayMs);
        }
      }

      // Launch concurrent workers
      var workers = [];
      for (var w = 0; w < concurrency; w++) {
        workers.push(worker());
      }
      await Promise.all(workers);

      logLine('\n  Done: ' + successCount + ' success, ' + failCount + ' failed.\n');
      return { stopped: stopped, success: successCount, fail: failCount };
    }

    async function saveState(success, fail, total, stopped) {
      var duration = Math.round((Date.now() - startTime) / 1000);
      try {
        var body = new FormData();
        body.append('total', total);
        body.append('success', success);
        body.append('fail', fail);
        body.append('stopped', stopped ? '1' : '0');
        body.append('duration', duration);
        body.append('urls', JSON.stringify(crawledUrls.slice(-200)));
        await fetch(saveEndpoint, { method: 'POST', body: body });
      } catch(e) {}
    }

    els.stop.addEventListener('click', function() {
      if (abortCtrl) abortCtrl.abort();
    });

    els.btn.addEventListener('click', async function() {
      var sitemap = document.getElementById('sitemap_url').value.trim();
      if (!sitemap) { alert('Please enter a valid Sitemap XML URL.'); return; }

      // Read current profile and apply custom values if needed
      var selectedProfile = document.querySelector('#profile-selector input[name="profile"]:checked');
      if (selectedProfile && selectedProfile.value === 'custom') {
        warmupSettings.concurrent = parseInt(document.getElementById('concurrent').value) || 3;
        warmupSettings.crawl_delay = parseInt(document.getElementById('crawl_delay').value) || 0;
        warmupSettings.crawl_timeout = parseInt(document.getElementById('crawl_timeout').value) || 30;
        warmupSettings.load_limit = parseFloat(document.getElementById('load_limit').value) || 0;
      }

      abortCtrl = new AbortController();
      setRunning(true);
      els.log.textContent = '';
      crawledUrls = [];
      globalCompleted = 0;
      globalTotal = 0;
      startTime = Date.now();

      var ua = document.getElementById('useragent').value.trim();
      ua = ua ? 'lscache_runner;' + ua : 'lscache_runner';
      var totalSuccess = 0, totalFail = 0;

      try {
        els.status.textContent = 'Loading URLs from sitemap...';
        var body = new FormData();
        body.append('sitemap_url', sitemap);
        body.append('shop_url', document.getElementById('shop_url').value.trim());

        var resp = await fetch(urlsEndpoint, { method: 'POST', body: body, signal: abortCtrl.signal });
        var data = await resp.json();

        if (!data.success) {
          logLine('Error: ' + (data.error || 'Failed to load URLs.'));
          els.bar.className = 'progress-bar bg-danger';
          els.bar.style.width = '100%';
          els.bar.textContent = 'Error';
          setRunning(false);
          return;
        }

        var sitemapUrls = data.sitemapUrls || [];
        var cookie = data.cookie || '';

        // Calculate total URLs across all phases
        globalTotal = sitemapUrls.length;
        if (cookie) globalTotal += sitemapUrls.length;
        if (warmupSettings.mobile_crawl && warmupSettings.mobile_useragent) {
          globalTotal += sitemapUrls.length;
          if (cookie) globalTotal += sitemapUrls.length;
        }

        logLine('Loaded ' + sitemapUrls.length + ' URLs from sitemap.');
        logLine('Concurrency: ' + warmupSettings.concurrent + ', Delay: ' + warmupSettings.crawl_delay + 'ms, Load limit: ' + warmupSettings.load_limit + '\n');

        // Phase 1: Desktop
        logHeader('LITESPEED CACHE — Full page cache (' + sitemapUrls.length + ' URLs)');
        var r1 = await crawlPhase('LiteSpeed Cache', sitemapUrls, '', ua);
        totalSuccess += r1.success; totalFail += r1.fail;
        if (r1.stopped) { finish(totalSuccess, totalFail, globalTotal, true); return; }

        if (cookie) {
          logHeader('LITESPEED CACHE — With vary cookie (' + sitemapUrls.length + ' URLs)');
          var r1b = await crawlPhase('LiteSpeed Cache (cookie)', sitemapUrls, cookie, ua);
          totalSuccess += r1b.success; totalFail += r1b.fail;
          if (r1b.stopped) { finish(totalSuccess, totalFail, globalTotal, true); return; }
        }

        // Phase 2: Mobile
        if (warmupSettings.mobile_crawl && warmupSettings.mobile_useragent) {
          var mobileUA = warmupSettings.mobile_useragent;
          logHeader('MOBILE CACHE — Full page cache (' + sitemapUrls.length + ' URLs)');
          var rm = await crawlPhase('Mobile Cache', sitemapUrls, '', mobileUA);
          totalSuccess += rm.success; totalFail += rm.fail;
          if (rm.stopped) { finish(totalSuccess, totalFail, globalTotal, true); return; }

          if (cookie) {
            logHeader('MOBILE CACHE — With vary cookie');
            var rmb = await crawlPhase('Mobile Cache (cookie)', sitemapUrls, cookie, mobileUA);
            totalSuccess += rmb.success; totalFail += rmb.fail;
            if (rmb.stopped) { finish(totalSuccess, totalFail, globalTotal, true); return; }
          }
        }

        if (cdnEnabled) {
          logHeader('CDN — Cloudflare');
          logLine('  URLs already requested through CDN in previous phases.\n');
        }

        finish(totalSuccess, totalFail, globalTotal, false);

      } catch (e) {
        if (e.name !== 'AbortError') {
          logLine('\nNetwork error: ' + e.message);
          els.bar.className = 'progress-bar bg-danger';
        } else {
          finish(totalSuccess, totalFail, globalTotal, true);
        }
        setRunning(false);
      }
    });

    function finish(success, fail, total, stopped) {
      els.bar.classList.remove('progress-bar-animated');
      var duration = Math.round((Date.now() - startTime) / 1000);
      if (stopped) {
        els.bar.className = 'progress-bar bg-secondary';
        els.status.textContent = 'Stopped. Success: ' + success + ', Failed: ' + fail + ' (' + duration + 's)';
        logLine('\n--- Stopped by user ---');
      } else if (fail === 0) {
        els.status.textContent = 'Completed! ' + success + ' URLs warmed up in ' + duration + 's';
        logLine('\n--- Completed successfully in ' + duration + 's ---');
      } else {
        els.bar.className = 'progress-bar bg-warning';
        els.status.textContent = 'Completed. Success: ' + success + ', Failed: ' + fail + ' (' + duration + 's)';
        logLine('\n--- Completed with ' + fail + ' errors in ' + duration + 's ---');
      }
      setRunning(false);
      saveState(success, fail, total, stopped);
    }

    // Copy buttons
    document.querySelectorAll('.js-copy-text').forEach(function (btn) {
      btn.addEventListener('click', function () {
        navigator.clipboard.writeText(btn.dataset.text).then(function () {
          var orig = btn.textContent;
          btn.textContent = 'Copied!';
          setTimeout(function () { btn.textContent = orig; }, 1500);
        });
      });
    });

  })();
  </script>
{% endblock %}
