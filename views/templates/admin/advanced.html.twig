{% extends '@PrestaShop/Admin/layout.html.twig' %}

{% block content %}
<div class="row justify-content-center">
  <div class="col-xl-12">

    <div class="alert alert-warning mb-4">
      These settings are intended for <strong>advanced users only</strong>. Incorrect values may break caching behavior.
    </div>

    <form method="post" autocomplete="off">

      {# Login Cookie #}
      <div class="card mb-3">
        <div class="card-header">
          <h3 class="card-header-title">Login Cookie</h3>
        </div>
        <div class="card-body">
          <div class="form-group row">
            <label class="form-control-label col-sm-3" for="login_cookie">Login Cookie Name</label>
            <div class="col-sm-9">
              <input type="text" class="form-control" id="login_cookie" name="login_cookie" value="{{ config.login_cookie }}" style="max-width:400px;">
              <small class="form-text text-muted">
                The server uses this cookie to determine if a user is logged in. Default: <code>_lscache_vary</code>.<br>
                Only alphanumeric characters and underscores. Case-sensitive. Must be unique across web applications on the same domain.<br>
                Useful when running multiple PrestaShop installations on the same domain (e.g. <code>example.com</code> and <code>example.com/shop2/</code>).
              </small>
            </div>
          </div>
        </div>
      </div>

      {# Vary Cookies #}
      <div class="card mb-3">
        <div class="card-header">
          <h3 class="card-header-title">Vary Cookies</h3>
        </div>
        <div class="card-body">
          <div class="form-group row">
            <label class="form-control-label col-sm-3" for="vary_cookies">Third-Party Vary Cookies</label>
            <div class="col-sm-9">
              <textarea class="form-control" id="vary_cookies" name="vary_cookies" rows="4" style="max-width:400px;">{{ config.vary_cookies }}</textarea>
              <small class="form-text text-muted">
                List third-party cookies that should create separate cache variants. One per line.<br>
                Only alphanumeric characters and underscores. Case-sensitive.<br>
                Useful for geolocation modules, A/B testing, or cookie consent plugins that change page content.
              </small>
            </div>
          </div>
        </div>
      </div>


      {# Submit #}
      <div class="card">
        <div class="card-footer d-flex justify-content-end">
          <button type="submit" name="submitAdvanced" class="btn btn-primary">Save</button>
        </div>
      </div>

    </form>

  </div>
</div>
{% include "@Modules/litespeedcache/views/templates/admin/_tools_dropdown.html.twig" %}
{% endblock %}
