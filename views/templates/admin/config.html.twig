{% extends '@PrestaShop/Admin/layout.html.twig' %}

{% block content %}
<div class="row justify-content-center">
  <div class="col-xl-12">

    <div class="alert alert-info">
      Cache settings have been moved to the <strong>Cache</strong> tab for better organization:
      <ul class="mb-0 mt-2">
        <li><strong>Page Cache</strong> — Enable cache, guest mode, mobile, customer groups, purge and cache rules</li>
        <li><strong>TTL</strong> — Cache timeouts (public, private, home, 404, product comments)</li>
        <li><strong>ESI</strong> — Edge Side Includes configuration</li>
        <li><strong>Object</strong> — Redis / Object cache</li>
      </ul>
    </div>

  </div>
</div>
