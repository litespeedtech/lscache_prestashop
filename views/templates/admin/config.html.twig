{% extends '@PrestaShop/Admin/layout.html.twig' %}

{% block content %}
<div class="row justify-content-center">
  <div class="col-xl-12">

    <form method="post" id="litespeedcache-config-form" autocomplete="off">

      {# ================================================================== #}
      {# SECTION 1 — General                                                 #}
      {# ================================================================== #}
      <div class="card mb-3">
        <div class="card-header">
          <h3 class="card-header-title">
            <i class="material-icons">settings</i>
            General
          </h3>
        </div>
        <div class="card-body">

          {# enable #}
          <div class="form-group row">
            <label class="form-control-label col-sm-3">
              Enable LiteSpeed Cache
            </label>
            <div class="col-sm-9">
              <span class="ps-switch">
                <input type="radio" name="enable" id="enable_off" value="0"
                  {% if not values.enable %}checked{% endif %}
                  {% if disabled %}disabled{% endif %}>
                <label for="enable_off">No</label>
                <input type="radio" name="enable" id="enable_on" value="1"
                  {% if values.enable %}checked{% endif %}
                  {% if disabled %}disabled{% endif %}>
                <label for="enable_on">Yes</label>
                <a class="slide-button btn"></a>
              </span>
            </div>
          </div>

          {# esi — always read-only / display only #}
          <div class="form-group row">
            <label class="form-control-label col-sm-3">
              Enable LiteSpeed ESI
            </label>
            <div class="col-sm-9">
              <span class="ps-switch">
                <input type="radio" name="esi" id="esi_off" value="0"
                  {% if not values.esi %}checked{% endif %}
                  disabled>
                <label for="esi_off">No</label>
                <input type="radio" name="esi" id="esi_on" value="1"
                  {% if values.esi %}checked{% endif %}
                  disabled>
                <label for="esi_on">Yes</label>
                <a class="slide-button btn"></a>
              </span>
              <small class="form-text text-muted">
                This setting is managed automatically and cannot be changed here.
              </small>
            </div>
          </div>

          {# ttl #}
          <div class="form-group row">
            <label class="form-control-label col-sm-3" for="ttl">
              Default Public Cache TTL
            </label>
            <div class="col-sm-9">
              <div class="input-group">
                <input type="text" class="form-control" id="ttl" name="ttl"
                  value="{{ values.ttl|default('') }}">
                <div class="input-group-append">
                  <span class="input-group-text">seconds</span>
                </div>
              </div>
              <small class="form-text text-muted">
                Default timeout for publicly cached pages. Recommended value is 86400.
              </small>
            </div>
          </div>

          {# privttl #}
          <div class="form-group row">
            <label class="form-control-label col-sm-3" for="privttl">
              Default Private Cache TTL
            </label>
            <div class="col-sm-9">
              <div class="input-group">
                <input type="text" class="form-control" id="privttl" name="privttl"
                  value="{{ values.privttl|default('') }}">
                <div class="input-group-append">
                  <span class="input-group-text">seconds</span>
                </div>
              </div>
              <small class="form-text text-muted">
                Default timeout for private cache ESI blocks. Suggested value is 1800. Must be less than 7200.
              </small>
            </div>
          </div>

          {# homettl #}
          <div class="form-group row">
            <label class="form-control-label col-sm-3" for="homettl">
              Home Page TTL
            </label>
            <div class="col-sm-9">
              <div class="input-group">
                <input type="text" class="form-control" id="homettl" name="homettl"
                  value="{{ values.homettl|default('') }}">
                <div class="input-group-append">
                  <span class="input-group-text">seconds</span>
                </div>
              </div>
              <small class="form-text text-muted">
                Default timeout for the home page.
              </small>
            </div>
          </div>

          {# 404ttl #}
          <div class="form-group row">
            <label class="form-control-label col-sm-3" for="404ttl">
              404 Pages TTL
            </label>
            <div class="col-sm-9">
              <div class="input-group">
                <input type="text" class="form-control" id="404ttl" name="404ttl"
                  value="{{ values['404ttl']|default('') }}">
                <div class="input-group-append">
                  <span class="input-group-text">seconds</span>
                </div>
              </div>
              <small class="form-text text-muted">
                Default timeout for all 404 (Not found) pages. 0 will disable caching for 404 pages.
              </small>
            </div>
          </div>

          {# pcommentsttl #}
          <div class="form-group row">
            <label class="form-control-label col-sm-3" for="pcommentsttl">
              Product Comments TTL
            </label>
            <div class="col-sm-9">
              <div class="input-group">
                <input type="text" class="form-control" id="pcommentsttl" name="pcommentsttl"
                  value="{{ values.pcommentsttl|default('') }}">
                <div class="input-group-append">
                  <span class="input-group-text">seconds</span>
                </div>
              </div>
              <small class="form-text text-muted">
                Timeout for product comments. 0 will disable caching.
              </small>
            </div>
          </div>

          {# diff_mobile #}
          <div class="form-group row">
            <label class="form-control-label col-sm-3">
              Separate Mobile View
            </label>
            <div class="col-sm-9">
              <span class="ps-switch">
                <input type="radio" name="diff_mobile" id="diff_mobile_off" value="0"
                  {% if not values.diff_mobile %}checked{% endif %}
                  {% if disabled %}disabled{% endif %}>
                <label for="diff_mobile_off">No</label>
                <input type="radio" name="diff_mobile" id="diff_mobile_on" value="1"
                  {% if values.diff_mobile %}checked{% endif %}
                  {% if disabled %}disabled{% endif %}>
                <label for="diff_mobile_on">Yes</label>
                <a class="slide-button btn"></a>
              </span>
              <small class="form-text text-muted">
                Enable if you have a separate mobile theme.
              </small>
            </div>
          </div>

          {# diff_customergroup #}
          <div class="form-group row">
            <label class="form-control-label col-sm-3" for="diff_customergroup">
              Separate Cache Copy per Customer Group
            </label>
            <div class="col-sm-9">
              <select class="form-control" id="diff_customergroup" name="diff_customergroup">
                <option value="0" {% if values.diff_customergroup == 0 %}selected{% endif %}>
                  No &mdash; Everyone shares the same view
                </option>
                <option value="1" {% if values.diff_customergroup == 1 %}selected{% endif %}>
                  Yes &mdash; Each group has its own view
                </option>
                <option value="2" {% if values.diff_customergroup == 2 %}selected{% endif %}>
                  Two views &mdash; One for logged-in, another for logged-out
                </option>
                <option value="3" {% if values.diff_customergroup == 3 %}selected{% endif %}>
                  One view &mdash; Only cache logged-out visitors
                </option>
              </select>
              <small class="form-text text-muted">
                Enable if different pricing is applied based on customer groups.
              </small>
            </div>
          </div>

          {# flush_all #}
          <div class="form-group row">
            <label class="form-control-label col-sm-3">
              Flush All Pages When Cache Cleared
            </label>
            <div class="col-sm-9">
              <span class="ps-switch">
                <input type="radio" name="flush_all" id="flush_all_off" value="0"
                  {% if not values.flush_all %}checked{% endif %}
                  {% if disabled %}disabled{% endif %}>
                <label for="flush_all_off">No</label>
                <input type="radio" name="flush_all" id="flush_all_on" value="1"
                  {% if values.flush_all %}checked{% endif %}
                  {% if disabled %}disabled{% endif %}>
                <label for="flush_all_on">Yes</label>
                <a class="slide-button btn"></a>
              </span>
              <small class="form-text text-muted">
                If disabled, manually flush all pages after clearing the PrestaShop cache.
              </small>
            </div>
          </div>

          {# flush_prodcat #}
          <div class="form-group row">
            <label class="form-control-label col-sm-3" for="flush_prodcat">
              Flush Product and Categories When Order Placed
            </label>
            <div class="col-sm-9">
              <select class="form-control" id="flush_prodcat" name="flush_prodcat"
                {% if disabled %}disabled{% endif %}>
                <option value="0" {% if values.flush_prodcat == 0 %}selected{% endif %}>
                  Flush product when quantity or stock changes; flush categories only when stock changes
                </option>
                <option value="1" {% if values.flush_prodcat == 1 %}selected{% endif %}>
                  Flush product and categories only when stock status changes
                </option>
                <option value="2" {% if values.flush_prodcat == 2 %}selected{% endif %}>
                  Flush product when stock changes; no categories
                </option>
                <option value="3" {% if values.flush_prodcat == 3 %}selected{% endif %}>
                  Always flush product and categories when quantity or stock change
                </option>
                <option value="4" {% if values.flush_prodcat == 4 %}selected{% endif %}>
                  Do not flush
                </option>
              </select>
              <small class="form-text text-muted">
                Determines how changes in product quantity and stock status affect product pages and category pages.
              </small>
            </div>
          </div>

          {# flush_home #}
          <div class="form-group row">
            <label class="form-control-label col-sm-3" for="flush_home">
              Flush Home Page When Order Placed
            </label>
            <div class="col-sm-9">
              <select class="form-control" id="flush_home" name="flush_home"
                {% if disabled %}disabled{% endif %}>
                <option value="0" {% if values.flush_home == 0 %}selected{% endif %}>
                  Do not flush
                </option>
                <option value="1" {% if values.flush_home == 1 %}selected{% endif %}>
                  Flush when stock changed for specified products
                </option>
                <option value="2" {% if values.flush_home == 2 %}selected{% endif %}>
                  Flush when stock or quantity changed for specified products
                </option>
              </select>
              <small class="form-text text-muted">
                No need to flush if the home page does not display products.
              </small>
            </div>
          </div>

          {# flush_homeinput #}
          <div class="form-group row">
            <label class="form-control-label col-sm-3" for="flush_homeinput">
              Specify Product IDs for Home Page Flush
            </label>
            <div class="col-sm-9">
              <textarea class="form-control" id="flush_homeinput" name="flush_homeinput"
                rows="3"
                {% if disabled %}disabled{% endif %}>{{ values.flush_homeinput|default('') }}</textarea>
              <small class="form-text text-muted">
                Space or comma separated. If empty, any product update triggers flush.
              </small>
            </div>
          </div>

          {# guestmode #}
          <div class="form-group row">
            <label class="form-control-label col-sm-3" for="guestmode">
              Enable Guest Mode
            </label>
            <div class="col-sm-9">
              <select class="form-control" id="guestmode" name="guestmode"
                {% if disabled %}disabled{% endif %}>
                <option value="0" {% if values.guestmode == 0 %}selected{% endif %}>
                  No &mdash; No default guest view
                </option>
                <option value="1" {% if values.guestmode == 1 %}selected{% endif %}>
                  Yes &mdash; Has default guest view
                </option>
                <option value="2" {% if values.guestmode == 2 %}selected{% endif %}>
                  First Page Only
                </option>
              </select>
              <small class="form-text text-muted">
                Speeds up the first page for new visitors.
              </small>
            </div>
          </div>

        </div>{# /card-body #}
      </div>{# /card General #}

      {# ================================================================== #}
      {# SECTION 2 — User-Defined Cache Rules                                #}
      {# ================================================================== #}
      <div class="card mb-3">
        <div class="card-header">
          <h3 class="card-header-title">
            <i class="material-icons">settings</i>
            User-Defined Cache Rules
          </h3>
        </div>
        <div class="card-body">

          {% if disabled %}
          <div class="alert alert-info">
            <i class="material-icons">info</i>
            These settings can only be set at the global level.
          </div>
          {% endif %}

          {# nocache_vars #}
          <div class="form-group row">
            <label class="form-control-label col-sm-3" for="nocache_vars">
              Do-Not-Cache GET Parameters
            </label>
            <div class="col-sm-9">
              <textarea class="form-control" id="nocache_vars" name="nocache_vars"
                rows="4"
                {% if disabled %}disabled{% endif %}>{{ values.nocache_vars|default('') }}</textarea>
              <small class="form-text text-muted">
                Comma-separated list of GET variables that prevents caching when present.
              </small>
            </div>
          </div>

          {# nocache_urls #}
          <div class="form-group row">
            <label class="form-control-label col-sm-3" for="nocache_urls">
              URL Blacklist
            </label>
            <div class="col-sm-9">
              <textarea class="form-control" id="nocache_urls" name="nocache_urls"
                rows="6"
                {% if disabled %}disabled{% endif %}>{{ values.nocache_urls|default('') }}</textarea>
              <small class="form-text text-muted">
                List of relative URLs to exclude from caching. Start with <code>/</code>. One per line.
                Use <code>*</code> for partial matches. Entries without <code>/</code> are treated as regex.
              </small>
            </div>
          </div>

          {# vary_bypass #}
          <div class="form-group row">
            <label class="form-control-label col-sm-3" for="vary_bypass">
              Context Vary Bypass
            </label>
            <div class="col-sm-9">
              <textarea class="form-control" id="vary_bypass" name="vary_bypass"
                rows="3"
                {% if disabled %}disabled{% endif %}>{{ values.vary_bypass|default('') }}</textarea>
              <small class="form-text text-muted">
                Comma-delimited context names to bypass vary. Supported values: <code>ctry</code>, <code>curr</code>, <code>lang</code>.
              </small>
            </div>
          </div>

        </div>{# /card-body #}
      </div>{# /card User-Defined Cache Rules #}

      {# ================================================================== #}
      {# SECTION 3 — Developer Testing                                        #}
      {# ================================================================== #}
      {# Submit                                                               #}
      {# ================================================================== #}
      <div class="card">
        <div class="card-footer d-flex justify-content-end">
          <button type="submit" name="submitConfig" class="btn btn-primary float-right">
            Save
          </button>
        </div>
      </div>

    </form>

  </div>{# /col #}
</div>{# /row #}
{% include "@Modules/litespeedcache/views/templates/admin/_tools_dropdown.html.twig" %}
{% endblock %}
